# Microsoft Foundry OpenAI-compatible endpoint for Chat Completions.
# Direct resource format: https://<resource-name>.openai.azure.com/openai/v1
AZURE_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/openai/v1

# Optional: route Responses API calls through a Foundry project or AI Gateway endpoint.
# Microsoft Learn format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
# The app appends /openai/v1 if you omit it.
# AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Optional: use an explicit Responses/Gateway endpoint instead of AZURE_FOUNDRY_PROJECT_ENDPOINT.
# AZURE_FOUNDRY_RESPONSES_ENDPOINT=https://your-gateway-or-project-endpoint/openai/v1

# Optional: required when your AI Gateway endpoint is exposed through Azure API Management
# and requires a subscription key. Do not commit real keys.
# AZURE_FOUNDRY_GATEWAY_SUBSCRIPTION_KEY=your-apim-subscription-key
